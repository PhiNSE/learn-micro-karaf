<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
           xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.2.0">

    <cm:property-placeholder persistent-id="com.example.microservicea">
        <cm:default-properties>
            <cm:property name="kafka.bootstrap.servers" value="kafka:9092"/>
            <cm:property name="redis.address" value="redis://redis:6379"/>
            <cm:property name="kafka.topic" value="job-events"/>
        </cm:default-properties>
    </cm:property-placeholder>

    <bean id="jsonUtil" class="com.example.common.event.JsonUtil"/>
    <bean id="clientFactory" class="com.example.microservicea.service.ClientFactory"/>

    <bean id="kafkaProducer"
          factory-ref="clientFactory"
          factory-method="createKafkaProducer">
        <argument value="${kafka.bootstrap.servers}"/>
    </bean>

    <bean id="redissonClient"
          factory-ref="clientFactory"
          factory-method="createRedissonClient">
        <argument value="${redis.address}"/>
    </bean>

    <bean id="kafkaEventProducer" class="com.example.microservicea.kafka.KafkaEventProducer">
        <argument ref="kafkaProducer"/>
        <argument ref="jsonUtil"/>
        <argument value="${kafka.topic}"/>
    </bean>

    <bean id="jobReadRepository" class="com.example.microservicea.redis.JobReadRepository">
        <argument ref="redissonClient"/>
    </bean>

    <bean id="jobCommandService" class="com.example.microservicea.service.JobCommandService">
        <argument ref="kafkaEventProducer"/>
    </bean>

    <bean id="jobQueryService" class="com.example.microservicea.service.JobQueryService">
        <argument ref="jobReadRepository"/>
    </bean>

    <bean id="jobResource" class="com.example.microservicea.api.JobResource">
        <argument ref="jobCommandService"/>
        <argument ref="jobQueryService"/>
    </bean>

    <service ref="jobResource">
        <interfaces>
            <value>java.lang.Object</value>
        </interfaces>
        <service-properties>
            <entry key="osgi.jaxrs.resource" value="true"/>
            <entry key="osgi.jaxrs.application.select" value="(osgi.jaxrs.name=default)"/>
        </service-properties>
    </service>
</blueprint>
